textures/it_barricade/plank_flatnohit
{
	qer_keyword wood
	qer_keyword wall
	surfaceparm wood
	surfaceparm nomarks
	{
		map textures/it_barricade/plank_flatnohit.tga
		rgbGen identity
		depthWrite
	}
	{
		map $lightmap
		blendFunc GL_DST_COLOR GL_ZERO
		rgbGen identity
		depthFunc equal
	}
}

