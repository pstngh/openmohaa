//changed by Vex attempting to have terrain actually accept world spawn lighting..
textures/it_terrain/it_t_31grass02_512
{
	qer_editorimage textures/it_terrain/it_t_31grass02_512.tga	
	qer_keyword italy
	qer_keyword terrain
	qer_keyword grass
	surfaceparm grass
	{
		map textures/it_terrain/it_t_31grass02_512.tga
		rgbGen identity
		depthWrite
	}
	{
		map $lightmap
		blendFunc GL_DST_COLOR GL_ZERO
		rgbGen identity
		depthFunc equal
	}
}




