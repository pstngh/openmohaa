textures/it_rock/it_t_rockface
{
	qer_editorimage textures/it_rock/it_t_rockface.tga	
	qer_keyword italy
	qer_keyword terrain
	qer_keyword rock
	surfaceparm rock
	{
		map textures/it_rock/it_t_rockface.tga
	nextbundle
		map $lightmap
