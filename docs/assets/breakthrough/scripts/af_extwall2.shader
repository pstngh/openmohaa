/////////////////////////////railing_balustrades

textures/af_extwall/af_e_balcrail_01a
{
	qer_keyword africa
	qer_keyword bizerte
	qer_keyword mosque
	qer_keyword wall
	qer_keyword railing
    qer_editorimage textures/af_extwall/af_e_balcrail_01a.tga
	surfaceparm alphashadow
	surfaceparm playerclip
	surfaceparm monsterclip
	surfaceparm nomarks
	surfaceparm metal
	surfaceparm nonsolid
	cull none
	{
		map textures/af_extwall/af_e_balcrail_01a.tga
		alphafunc GE128
		rgbGen identity
		depthWrite depthWrite
	}
	{
		map $lightmap
		blendFunc GL_DST_COLOR GL_ZERO
		rgbGen identity
		depthFunc equal
	}
}

