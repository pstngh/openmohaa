textures/central_europe_winter/natesnow_rough256
{
	qer_keyword snow
	qer_keyword terrain
	surfaceparm snow
	qer_editorimage textures/central_europe_winter/natesnow_rough256.tga
	{
		map textures/central_europe_winter/natesnow_rough256.tga
		depthWrite
		rgbGen identity
	}
	{
		map $lightmap
		rgbGen identity
		blendFunc GL_DST_COLOR GL_ZERO
		depthFunc equal
	}
}

