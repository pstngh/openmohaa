textures/it_road/ibeam_vert
{
	qer_keyword trim
	qer_keyword metal
	surfaceParm metal
	surfaceParm weaponclip
	surfaceParm shootonly
	surfaceparm nonsolid
	surfaceParm trans
	cull none
	{
		map textures/it_road/ibeam_vert.tga
		rgbGen identity
		depthWrite
	}
	{
		map $lightmap
		blendFunc GL_DST_COLOR GL_ZERO
		rgbGen identity
		depthFunc equal
	}
}

