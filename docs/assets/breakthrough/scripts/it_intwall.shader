//////////////////////////////////palermo_interior_walls
textures/it_intwall/wainscot01a
{
	qer_editorimage textures/it_extwall/textures/it_intwall/wainscot01a.tga	
	qer_keyword italy
	qer_keyword palermo
	qer_keyword wallpaper
	qer_keyword wall
	surfaceparm wood
	{
		map textures/it_intwall/wainscot01a.tga
	nextbundle
		map $lightmap
	}
}

