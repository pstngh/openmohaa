stuka_prop
{
	cull none
	qer_editorimage textures/models/vehicles/stuka_explo2/Prop.tga
	{
		clampmap textures/models/vehicles/stuka_explo2/Prop.tga
		blendfunc blend
		rgbGen lightingSpherical
		tcmod rotate 300
