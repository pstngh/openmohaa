fan_anim_map_room
{
   nomipmaps
   nopicmip
   cull none
   force32bit
   surfaceparm nolightmap
   {
      animMap 32 textures/mohmenu/fan_a_0001.tga textures/mohmenu/fan_a_0002.tga textures/mohmenu/fan_a_0003.tga textures/mohmenu/fan_a_0004.tga textures/mohmenu/fan_a_0005.tga textures/mohmenu/fan_a_0006.tga textures/mohmenu/fan_a_0007.tga textures/mohmenu/fan_a_0008.tga textures/mohmenu/fan_a_0009.tga
      rgbgen   global
      blendFunc GL_SRC_ALPHA GL_ONE_MINUS_SRC_ALPHA
   }
}

