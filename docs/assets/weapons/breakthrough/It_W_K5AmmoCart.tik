TIKI

setup
{
	scale 0.52			// Set default scale to 16/30.5 since world is in 16 units per foot and model is in cm's
	path models/weapons/K5_AmmoCart
	skelmodel It_W_K5AmmoCart.skd
	surface It_W_K5AmmoCart shader It_W_K5ShellCart
	
}

init
{
	server
	{
		classname ScriptModel
	}
}


animations
{
	idle		It_W_K5AmmoCart.skc
}

