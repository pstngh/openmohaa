enfield
{
	qer_editorimage models/weapons/enfield/enfield.tga
	{
		map models/weapons/enfield/enfield.tga
		rgbGen lightingSpherical
	}
}

enfieldcull
{
	qer_editorimage models/weapons/enfield/enfield.tga
	cull none
	{
		map models/weapons/enfield/enfield.tga
		rgbGen lightingSpherical
		alphaFunc ge128
		depthWrite
	}
}

