ppsh_smg
{
	qer_editorimage textures/models/weapons/ppsh_smg.tga
	{
		map textures/models/weapons/ppsh_smg.tga
		rgbGen lightingSpherical
	}
}

ppsh_smgcull
{
	qer_editorimage textures/models/weapons/ppsh_smg.tga
	cull none
	{
		map textures/models/weapons/ppsh_smg.tga
		rgbGen lightingSpherical
		alphaFunc ge128
		depthWrite
	}
}

