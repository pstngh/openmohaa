textures/ta_berlin/window3broken
{
	qer_editorimage textures/ta_berlin/window3frame.tga
	qer_keyword broken
	qer_keyword window
	qer_keyword glass
	surfaceparm fence
	surfaceparm wood
//	cull none
	{
		map textures/test/window_env.tga
