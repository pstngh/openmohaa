// Save button
// save the tweaks
resource
Button
{
	title "Save"
	name "Default"
	rect 540 128 100 16
	fgcolor 1.00 1.00 1.00 1.00
	bgcolor 0.80 0.00 0.00 1.00
	borderstyle "INDENT_BORDER"
	stuffcommand "lod_save 1"
}

end.
