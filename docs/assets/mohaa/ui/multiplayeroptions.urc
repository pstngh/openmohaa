resource
Label
{
title "modelentry"
name "Default"
rect 64 88 240 32
fgcolor 1.00 1.00 1.00 1.00
bgcolor 0.50 0.50 0.50 0.00
borderstyle "NONE"
linkcvar "ui_dm_playermodel"
font facfont-20
textalign xcenter

}
resource
Label
{
title "modelentry"
name "Default"
rect 336 88 240 32
fgcolor 1.00 1.00 1.00 1.00
bgcolor 0.50 0.50 0.50 0.00
borderstyle "INDENT_BORDER"
linkcvar "ui_dm_playergermanmodel"
font facfont-20
textalign xcenter

}
resource
Label
{
title "ratedisplay"
name "Default"
rect 224 128 192 16
fgcolor 1.00 1.00 1.00 1.00
bgcolor 0.50 0.50 0.50 0.00
borderstyle "NONE"
shader "textures/menu/blank2"
linkcvar "rate"
linkstring 2500 "28.8k modem"
linkstring 3000 "33.6k modem"
linkstring 4000 "56k modem"
linkstring 5000 "ISDN"
linkstring 20000 "Cable"
linkstring 25000 "xDSL"
linkstring 30000 "LAN"

}
resource
Button
{
name "Default"
rect 536 448 96 24
fgcolor 1.00 1.00 1.00 1.00
bgcolor 0.50 0.50 0.50 0.00
borderstyle "NONE"
shader "textures/mohmenu/apply"
hovershader "textures/mohmenu/apply_h"
clicksound "sound/menu/apply.wav"
stuffcommand "ui_applyplayermodel;ui_checkrestart;Popmenu 0"
}
resource
CheckBox
{
name "Force Models"
rect 448 128 120 16
fgcolor 1.00 1.00 1.00 1.00
bgcolor 0.50 0.50 0.50 0.00
borderstyle "NONE"
clicksound "sound/menu/scroll.wav"
linkcvar "cg_forceModel"
checked_shader "textures/menu/checkbox_checked"
unchecked_shader "textures/menu/checkbox_unchecked"

}
resource
PulldownMenuContainer
{
title "list"
name "ratelist"
rect 200 128 16 16
fgcolor 1.00 1.00 1.00 1.00
bgcolor 0.50 0.50 0.50 0.00
borderstyle "NONE"
menushader "MENU" "multiarrow"
selmenushader "MENU" "multiarrow_h"
addpopup "MENU" "28.8k modem" command "set rate 2500"
addpopup "MENU" "33.6k modem" command "set rate 3000"
addpopup "MENU" "56k modem" command "set rate 4000"
addpopup "MENU" "ISDN" command "set rate 5000"
addpopup "MENU" "CABLE" command "set rate 20000"
addpopup "MENU" "xDSL" command "set rate 25000"
addpopup "MENU" "LAN" command "set rate 30000"

}
end.
