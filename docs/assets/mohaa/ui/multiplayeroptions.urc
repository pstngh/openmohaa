menu "mpoptions" 640 479 NONE 0
bgcolor 1 1 1 1
borderstyle NONE
bgfill 0 0 0 1
fullscreen 1
//vidmode 3
//fadein 0.5
virtualres 1
include "ui/multiplayerback.inc"







resource
Label
{
title "Allies Player Model display"
name "Default"
rect 0 136 368 344
fgcolor 1.00 1.00 1.00 1.00
bgcolor 0.50 0.50 0.50 0.00
borderstyle "INDENT_BORDER"
linkcvar "ui_disp_playermodel"
rendermodel 1
modeloffset "60 8 0"
modelrotateoffset "0 0 0"
modelangles "10 180 0"
modelscale 1.0
modelanim americanselectionidle

}
resource
Label
{
title "German Player Model display"
name "Default"
rect 272 136 368 344
fgcolor 1.00 1.00 1.00 1.00
bgcolor 0.50 0.50 0.50 0.00
borderstyle "INDENT_BORDER"
linkcvar "ui_disp_playergermanmodel"
rendermodel 1
modeloffset "60 -8 0"
modelrotateoffset "0 0 0"
modelangles "10 180 0"
modelscale 1.0
modelanim germanselectionidle

}
resource
Label
{
name "Default"
rect 384 0 256 256
fgcolor 0.29 0.29 0.29 1.00
bgcolor 0.50 0.50 0.50 0.00
borderstyle "RAISED"
shader "modelselect_b"
}
resource
Label
{
name "Default"
rect 0 0 512 256
fgcolor 0.29 0.29 0.29 1.00
bgcolor 0.50 0.50 0.50 0.00
borderstyle "RAISED"
