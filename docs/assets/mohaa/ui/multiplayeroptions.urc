}
resource
Label
{
name "Default"
rect 0 0 256 256
fgcolor 1.00 1.00 1.00 1.00
bgcolor 0.50 0.50 0.50 0.00
borderstyle "NONE"
shader "textures/mohmenu/voodoo/modelselect_a"
enabledcvar "ui_voodoo"
}
resource
Label
{
name "Default"
rect 424 408 112 56
fgcolor 0.29 0.29 0.29 1.00
bgcolor 0.50 0.50 0.50 0.00
borderstyle "RAISED"
shader "textures/mohmenu/pmshadow"
}
resource
Button
{
name "Default"
rect 8 448 96 24
fgcolor 1.00 1.00 1.00 1.00
bgcolor 0.50 0.50 0.50 0.00
borderstyle "3D_BORDER"
shader "textures/mohmenu/back"
hovershader "textures/mohmenu/back_h"
clicksound "sound/menu/back.wav"
stuffcommand "Popmenu 1"
}
resource
Label
{
name "Default"
rect 104 408 112 56
fgcolor 0.29 0.29 0.29 1.00
bgcolor 0.50 0.50 0.50 0.00
borderstyle "RAISED"
shader "textures/mohmenu/pmshadow"
}
resource
Field
{
title "nameentry"
name "Default"
rect 240 16 288 32
fgcolor 1.00 1.00 1.00 1.00
bgcolor 0.50 0.50 0.50 0.00
borderstyle "INDENT_BORDER"
clicksound "sound/menu/scroll.wav"
linkcvar "ui_name"
font facfont-20
textalign left

}
resource
Button
{
name "Axis Player Model"
rect 360 56 192 24
fgcolor 1.00 1.00 1.00 1.00
bgcolor 0.75 0.75 0.75 0.00
borderstyle "NONE"
shader "menu_button_trans"
hovershader "menu_button_glow"
clicksound "sound/menu/scroll.wav"
stuffcommand "playermodel 1"
//shader "textures/mohmenu/quit"
//hovershader "textures/mohmenu/quit_h"
font facfont-20
//textalign right

}
resource
Button
{
name "88 56 192 24"
rect 88 56 192 24
fgcolor 1.00 1.00 1.00 1.00
bgcolor 0.75 0.75 0.75 0.00
borderstyle "NONE"
shader "menu_button_trans"
hovershader "menu_button_glow"
