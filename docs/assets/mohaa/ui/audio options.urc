menu "audio_options" 640 480 NONE 0
fullscreen 1
//vidmode 3
bgcolor 0 0 0 1 
borderstyle NONE
bgfill 0 0 0 1 
fullscreen 1
//fadein 0.5
virtualres 1
//include "ui/common.inc"








