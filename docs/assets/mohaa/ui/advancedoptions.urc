addpopup "MENU" "Medium" command "set r_lodscale 0.45 ; set r_lodcap 0.35 ; set r_lodviewmodelcap 0.45"
addpopup "MENU" "High" command "set r_lodscale 0.55 ; set r_lodcap 0.5 ; set r_lodviewmodelcap 0.55"
addpopup "MENU" "Higher" command "set r_lodscale 0.9 ; set r_lodcap 0.9 ; set r_lodviewmodelcap 0.9"
addpopup "MENU" "Highest" command "set r_lodscale 1.1 ; set r_lodcap 1.0 ; set r_lodviewmodelcap 1.0"

