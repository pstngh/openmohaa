selmenushader "MENU" "textures/menu/pulldownarrow_sel"
addpopup "MENU" "Low Detail" command "set ter_error 10; set ter_maxlod 3; set ter_maxtris 16384"
addpopup "MENU" "Medium Detail" command "set ter_error 9; set ter_maxlod 4; set ter_maxtris 16384"
addpopup "MENU" "High Detail" command "set ter_error 7; set ter_maxlod 5; set ter_maxtris 16384"
addpopup "MENU" "Max Detail" command "set ter_error 4; set ter_maxlod 6; set ter_maxtris 24576"

}
