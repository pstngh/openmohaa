textures/wilderness/bocage_canopy1
{
	qer_editorimage textures/wilderness/pj_maskedtrees1.tga
	qer_keyword folliage
	qer_keyword natural
	qer_keyword masked
	qer_keyword tree
	surfaceparm foliage
	surfaceparm fence
	surfaceparm alphashadow
	nopicmip
//	cull none
//	cull front
	{
		map textures/wilderness/pj_maskedtrees1.tga
		depthWrite
		alphaFunc GE128
	nextbundle
		map $lightmap
	}
}

