textures/wilderness/m3l3grass_1
{
	qer_keyword grass
	qer_keyword floor
	qer_keyword natural
	qer_keyword flat
	surfaceparm grass
	{
		map textures/wilderness/m3l3grass_1.tga
		depthWrite
		rgbGen identity
	}
	{
		map $lightmap
		rgbGen identity
		blendFunc GL_DST_COLOR GL_ZERO
		depthFunc equal
	}
} 

