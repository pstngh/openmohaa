textures/sky/africanight
{
	qer_keyword utility
	qer_keyword sky
	surfaceparm nolightmap
	surfaceparm noimpact
	surfaceparm sky
	skyParms env/mohnight1 512 -
	{
		map textures/sky/talonclouds.tga
		blendFunc add
		tcMod scroll .005 .003
		tcMod scale 3 2
	}
}

