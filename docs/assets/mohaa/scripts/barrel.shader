textures/barrel/black_side
{
	surfaceparm metal
	{
		map textures/barrel/black_side.tga
		depthWrite
		rgbGen identity
	}
	{
		map $lightmap
		rgbGen identity
		blendFunc GL_DST_COLOR GL_ZERO
		depthFunc equal
	}
}

