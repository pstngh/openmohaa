frogman
{
	cull none
	qer_editorimage textures/models/human/germanmaps/Frogman/Frogman.tga
	{
		map textures/common/reflection2.tga
		rgbGen lightingSpherical
		tcgen environmentmodel
	}
	{
		map textures/models/human/germanmaps/Frogman/Frogman.tga
		rgbGen lightingSpherical
		blendfunc gl_one gl_src_alpha 
	}
}

