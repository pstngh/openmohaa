//afrika korps heads and hands
///////////////////////////////////////////////////////////////////////////////

facewrap
{
	qer_editorimage textures/models/human/germanmaps/afrikakorps/DAkfacewrap.tga
	{
		map textures/common/reflection1.tga
		rgbGen lightingSpherical
		tcgen environmentmodel
	}
	{
		map textures/models/human/germanmaps/afrikakorps/DAkfacewrap.tga
		rgbGen lightingSpherical
		blendfunc gl_one_minus_src_alpha gl_src_alpha 
	}
}

