textures/interior_northafrica/bookcase_top
{
	qer_keyword special
	qer_keyword panel
	qer_keyword wood
	qer_keyword flat
	surfaceparm wood
	{
		map textures/interior_northafrica/bookcase_top.tga
		depthWrite
		rgbGen identity
	}
	{
		map $lightmap
		rgbGen identity
		blendFunc GL_DST_COLOR GL_ZERO
		depthFunc equal
	}
}

