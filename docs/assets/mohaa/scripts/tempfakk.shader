textures/tempfakk/wl_neweden_1
{
	{
		map textures/tempfakk/wl_neweden_1.tga
		depthWrite
		rgbGen identity
	}
	{
		map $lightmap
		rgbGen identity
		blendFunc GL_DST_COLOR GL_ZERO
		depthFunc equal
	}
}

