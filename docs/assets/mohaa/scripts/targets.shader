textures/test/15yds
{
	qer_keyword special
	surfaceparm stone
	nopicmip
	{
		map textures/test/15yds.tga
		depthWrite
		rgbGen identity
	}
	{
		map $lightmap
		rgbGen Identity
		blendFunc GL_DST_COLOR GL_ZERO
		depthFunc equal
	}
}

