textures/normandy/bunker_conc1
{
	qer_keyword wall
	qer_keyword concrete
	surfaceparm stone
	{
		map textures/normandy/bunker_conc1.tga
		depthWrite
		rgbGen identity
	}
	{
		map $lightmap
		rgbGen identity
		blendFunc GL_DST_COLOR GL_ZERO
		depthFunc equal
	}
}

