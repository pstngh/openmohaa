textures/tempsign/allbarracks
{
	qer_keyword signs
	{
		map textures/tempsign/allbarracks.tga
		depthWrite
		rgbGen identity
	}
	{
		map $lightmap
		rgbGen identity
		blendFunc GL_DST_COLOR GL_ZERO
		depthFunc equal
	}
}

