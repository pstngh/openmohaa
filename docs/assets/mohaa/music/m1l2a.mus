path sound/amb_stereo

normal Amb_M1_TownExt.mp3 // Player Start
aux1 Amb_M1_TownExt.mp3 // Exterior 1 - this is for the exterior up to the cliffs
aux2 Amb_M1_Interior_01.mp3 // Interior 1 - this is for all interiors
aux3 Amb_M1_Cliff_01.mp3 // Exterior 2 - this is for the cliff exterior, starting at the exploded wooden gate


!normal volume 1
!normal loop

!aux1 volume 1
!aux1 loop

!aux2 volume .7
!aux2 loop

!aux3 volume 1
!aux3 loop
