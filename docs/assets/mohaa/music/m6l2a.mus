path sound/amb_stereo

normal Amb_M6_TownExt.mp3 // Default - player start

aux1 Amb_M6_TownExt.mp3 // Exterior 1 - this is for the exterior up to train station
aux2 Amb_M6_BuildingInnerInt.mp3 // Interior 1 - all interiors at the train station

!normal volume 1
!normal loop

!aux1 volume 1
!aux1 loop

!aux2 volume 0.5
!aux2 loop



