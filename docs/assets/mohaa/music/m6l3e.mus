path sound/amb_stereo

normal Amb_M6_WoodsExt_01.mp3 // Default

aux1 Amb_M6_WoodsExt_01.mp3 // Exterior 1 - this is for the entire level

aux2 null.wav // To turn off the ambients for the credits rolling


!normal volume 1.5
!normal loop

!aux1 volume 1.5
!aux1 loop

!aux2 volume 1.5
!aux2 loop





